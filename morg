    if os.path.exists(os.path.join(parent_dir, INDEX_FILE)):
        nav_top = f"""<a href="../{INDEX_FILE}" class="plain">Top</a>"""
    if this_year > 0:
        last_year = this_year - 1
        next_year = this_year + 1
        last_year_path = os.path.join(parent_dir, str(last_year))
        next_year_path = os.path.join(parent_dir, str(next_year))
