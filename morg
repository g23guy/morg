# Supported extensions
ext_image_str = "jpg|jpeg|png|bmp|tif|tiff|heic|webp|pgm|ppm|pmb|pnm|jfif|jp2|j2k|jxl"
ext_image_convert_str = "heic|tiff|tif"
ext_video_str = "mp4|mov|avi|mkv|wmv|webm|3gp"
ext_video_convert_str = "mov"
ext_sound_str = "mp3|wav|snd|m4a|aac|aiff|flac|ogg|amr|mp2"
ext_all_str = "|".join([ext_image_str, ext_video_str, ext_sound_str])
ext_images = tuple([f".{ext}" for ext in ext_image_str.split('|')])
ext_images_convert = tuple([f".{ext}" for ext in ext_image_convert_str.split('|')])
ext_videos = tuple([f".{ext}" for ext in ext_video_str.split('|')])
ext_videos_convert = tuple([f".{ext}" for ext in ext_video_convert_str.split('|')])
ext_sounds = tuple([f".{ext}" for ext in ext_sound_str.split('|')])
ext_all = tuple([f".{ext}" for ext in ext_all_str.split('|')])

# Setup HEIF and MIME
pillow_heif.register_heif_opener()
mimetypes.add_type('image/heic', '.heic')
mimetypes.add_type('image/jfif', '.jfif')
mimetypes.add_type('image/jxl', '.jxl')
mimetypes.add_type('audio/amr', '.amr')


# Regex: YYYYMMDD-HHMMSS[-State][-Location][-Description](_#).ext
# group(1): YYYYMMDD-HHMMSS
# group(2): [-State]
# group(3): [-Location]
# group(4): [-Description]
FILENAME_PATTERN = re.compile(r"^(\d{8}-\d{6})(?:-([^-_\.]+))?(?:-([^-_\.]+))?(?:-([^-_\.]+))?(?:_(\d+))?\.(" + ext_all_str + ")$")

def get_mime_list(filepath):
    mime_type, _ = mimetypes.guess_type(filepath)
    if mime_type:
        parts = mime_type.split('/')
        return [parts[0], parts[-1]]
    return ["unknown", "unknown"]

def get_datetime(filepath):
    ext = os.path.splitext(filepath)[-1].lower()

    if ext in ext_images:
        try:
            with Image.open(filepath) as img:
                exif_data = img._getexif()
                if exif_data:
                    for tag, value in exif_data.items():
                        if TAGS.get(tag) == "DateTimeOriginal":
                            return datetime.strptime(value, "%Y:%m:%d %H:%M:%S"), "creation"
                        elif TAGS.get(tag) == "DateTimeDigitized":
                            return datetime.strptime(value, "%Y:%m:%d %H:%M:%S"), "digitized"
        except Exception: pass

    if ext in ext_videos or ext in ext_sounds:
        try:
            with exiftool.ExifToolHelper() as et:
                metadata = et.get_metadata(filepath)
                for d in metadata:
                    value = d.get('EXIF:DateTimeOriginal') or d.get('XMP:DateTimeOriginal') or d.get('QuickTime:CreateDate')
                    return datetime.strptime(value, "%Y:%m:%d %H:%M:%S"), "creation"
        except Exception: pass

    return datetime.fromtimestamp(os.path.getmtime(filepath)), "modified"

def set_datetime(file_path, dt):
    updated_datetime = {'meta': False, 'fs': False}
    ext = os.path.splitext(file_path)[-1].lower()
    dt_stamp = dt.timestamp()
    new_date = dt.strftime("%Y:%m:%d %H:%M:%S")

    if ext in ext_images:
        try:
            with Image.open(file_path) as img:
                exif_dict = piexif.load(img.info.get('exif', b""))
                exif_dict['Exif'][piexif.ExifIFD.DateTimeOriginal] = new_date.encode('utf-8')
                exif_dict['Exif'][piexif.ExifIFD.DateTimeDigitized] = new_date.encode('utf-8')
                exif_bytes = piexif.dump(exif_dict)
                img.save(file_path, exif=exif_bytes)
            updated_datetime['meta'] = True
        except Exception: pass

    if ext in ext_videos or ext in ext_sounds:
        tags_to_set = {
            "EXIF:DateTimeOriginal": new_date,
            "XMP:DateTimeOriginal": new_date,
            "QuickTime:CreateDate": new_date
        }
        params = ["-P", "-overwrite_original"]

        try:
            with exiftool.ExifToolHelper() as et:
                # Note: set_tags expects a list of files even if it's just one
                et.set_tags([file_path], tags=tags_to_set, params=params)
            updated_datetime['meta'] = True
        except Exception: pass

    try:
        os.utime(file_path, (dt_stamp, dt_stamp))
        updated_datetime['fs'] = True
    except Exception: pass

    return updated_datetime

def override_dt(dt_old, given_date, given_time):
    if given_date:
        new_date = given_date
    else:
        new_date = datetime.strftime(dt_old, "%Y%m%d")

    if given_time:
        new_time = given_time
    else:
        new_time = datetime.strftime(dt_old, "%H%M%S")

    dt_new_str = new_date + "-" + new_time
    dt_new = datetime.strptime(dt_new_str, "%Y%m%d-%H%M%S")
    return dt_new, "override"

def get_all_logs(target_path, recurse):
    logs = []
    base_dir = target_path if os.path.isdir(target_path) else os.path.dirname(os.path.abspath(target_path))
    if recurse:
        for root, _, files in os.walk(base_dir):
            for f in files:
                if f.startswith("process_log_") and f.endswith(".json"):
                    logs.append(os.path.join(root, f))
    else:
        if os.path.exists(base_dir):
            logs = [os.path.join(base_dir, f) for f in os.listdir(base_dir) 
                    if f.startswith("process_log_") and f.endswith(".json")]
    return sorted(logs)

def print_log_table(log_path, verbose):
    """Prints a log file with dynamic column widths for full filenames."""
    try:
        with open(log_path, 'r') as f:
            log_data = json.load(f)
        if not log_data: return

        # Calculate widths based on content
        w_orig = max(len(e['original_name']) for e in log_data)
        w_new = max(len(e['new_name']) for e in log_data)
        w_used = max(len(e['date_used']) for e in log_data)
        w_source = max(len(e['date_source']) for e in log_data)
        w_action = max(len(e['action']) for e in log_data)
        w_orig, w_new = max(w_orig, 13), max(w_new, 8)

        print(f"\nLOG: {log_path}")
        if verbose:
            header = f"{'ORIGINAL_NAME':<{w_orig}} | {'NEW_NAME':<{w_new}} | {'ACTION':<{w_action}} | {'DATE':<{w_used}} | {'SOURCE':<{w_source}} | {'META':<4} | {'FS':<2} | {'TYPE':<10}"
            print(header)
            print("-" * len(header))
            for e in log_data:
                print(f"{e['original_name']:<{w_orig}} | {e['new_name']:<{w_new}} | {e['action'].upper():<{w_action}} | {e['date_used']:<{w_used}} | {e['date_source']:<{w_source}} | {e['updated_datetime']['meta']:<4} | {e['updated_datetime']['fs']:<2} | {e['mime_type'][0]:<10}")
        else:
            header = f"{'ORIGINAL_NAME':<{w_orig}} | {'NEW_NAME':<{w_new}} | {'ACTION':<{w_action}} | {'DATE':<{w_used}} | {'SOURCE':<{w_source}} | {'META':<4} | {'FS':<2} | {'TYPE':<10}"
            print(header)
            print("-" * len(header))
            for e in log_data:
                print(f"{e['original_name']:<{w_orig}} | {e['new_name']:<{w_new}} | {e['action'].upper():<{w_action}} | {e['date_used']:<{w_used}} | {e['date_source']:<{w_source}} | {e['updated_datetime']['meta']:<4} | {e['updated_datetime']['fs']:<2} | {e['mime_type'][0]:<10}")
    except Exception as e:
        print(f"Error reading log {log_path}: {e}")

def display_logs(target_path, verbose, all_subdirs):
    logs = get_all_logs(target_path, recurse=all_subdirs)
    if not logs:
        print("No logs found.")
        return
    
    if all_subdirs:
        # Get latest log from each unique directory
        latest_per_dir = {}
        for l in logs: latest_per_dir[os.path.dirname(l)] = l
        for lp in latest_per_dir.values(): print_log_table(lp, verbose)
    else:
        print_log_table(logs[-1], verbose)

def restore_original_names(target_path, recurse):
    # once files are converted, they are not converted back
    logs = get_all_logs(target_path, recurse)
    if not logs: return
    logs.reverse()
    for log_path in logs:
        log_dir = os.path.dirname(log_path)
        with open(log_path, 'r') as f:
            for entry in json.load(f):
                if entry.get('status') == 'success':
                    curr, orig = os.path.join(log_dir, entry['new_name']), os.path.join(log_dir, entry['original_name'])
                    if entry.get('action') == 'converted':
                        print(f"[CONVERTED] {entry['original_name']} -> {entry['new_name']}: Cannot be restored")
                    elif os.path.exists(curr):
                        os.rename(curr, orig)
                        print(f"[RESTORED]  {entry['new_name']} -> {entry['original_name']}")
    for log_path in logs: os.remove(log_path)

def reverse_last_session(target_path, recurse):
    # once files are converted, they are not converted back
    logs = get_all_logs(target_path, recurse)
    if logs:
        with open(logs[-1], 'r') as f:
            for e in json.load(f):
                curr, orig = os.path.join(os.path.dirname(logs[-1]), e['new_name']), os.path.join(os.path.dirname(logs[-1]), e['original_name'])
                if e.get('action') == 'converted':
                    print(f"[CONVERTED] {e['original_name']} -> {e['new_name']}: Cannot be reversed")
                elif os.path.exists(curr): 
                    os.rename(curr, orig)
                    print(f"[REVERSED]  {e['new_name']} -> {e['original_name']}")

def filename_to_modification_dt(target_input, recurse, verbose):
    search_pattern = os.path.join(target_input, "**" if recurse else "", "*") if os.path.isdir(target_input) else target_input
    files_to_process = glob.glob(search_pattern, recursive=recurse)
    file_cnt = 0
    file_eval = 0

    dir_groups = {}
    for f_path in files_to_process:
        if os.path.isfile(f_path):
            d = os.path.dirname(os.path.abspath(f_path))
            if d not in dir_groups: dir_groups[d] = []
            dir_groups[d].append(f_path)

    for root, files in dir_groups.items():
        change_log = []
        action = "updated"
        action_str = "[" + action.upper() + "]"
        source = "filename"
        updated_datetime = {'meta': False, 'fs': False}
        for this_path in sorted(files):
            file_eval += 1
            filename = os.path.basename(this_path)
            new_name = filename
            match = FILENAME_PATTERN.match(filename.lower())

            s_val = match.group(2) if match else ""
            l_val = match.group(3) if match else ""
            d_val = match.group(4) if match else ""

            if match:
                print(f"{action_str:<11} {filename} -> ", end="", flush=True)
                file_cnt += 1
                try:
                    dt = datetime.strptime(match.group(1), "%Y%m%d-%H%M%S")
                    updated_datetime = set_datetime(this_path, dt)
                except Exception as e: print(f"Error: {e} => ", end='', flush=True)

                change_log.append({
                    "original_name": filename, 
                    "original_path": os.path.abspath(this_path),
                    "new_name": new_name, 
                    "state": s_val, 
                    "location": l_val, 
                    "description": d_val,
                    "mime_type": get_mime_list(this_path),
                    "updated_datetime": updated_datetime,
                    "date_used": dt.isoformat(), 
                    "date_source": source, 
                    "action": action, 
                    "status": "success"
                })
                print(f"{new_name}")

        if change_log:
            with open(os.path.join(root, f"process_log_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"), 'w') as f:
                json.dump(change_log, f, indent=4)

    if file_cnt > 0: display_logs(target_input, verbose, all_subdirs=False)
    action_str = "[SUMMARY]"
    print(f"{action_str:<11} Processed {file_cnt} matching files out of {file_eval} found")

def process_media(target_input, recurse, adjacent, state_arg, location_arg, description_arg, given_date, given_time, time_sequenced, forced, convert, convert_remove, verbose):
    extensions = ext_all
    search_pattern = os.path.join(target_input, "**" if recurse else "", "*") if os.path.isdir(target_input) else target_input
    files_to_process = glob.glob(search_pattern, recursive=recurse)
    overridden = False
    file_cnt = 0
    file_eval = 0
    if given_date or given_time: overridden = True
    if time_sequenced: overridden = True

    dir_groups = {}
    for f_path in files_to_process:
        if os.path.isfile(f_path):
            d = os.path.dirname(os.path.abspath(f_path))
            if d not in dir_groups: dir_groups[d] = []
            dir_groups[d].append(f_path)

    all_logs = get_all_logs(target_input, recurse)
    log_metadata = {}
    for log in all_logs:
        try:
            with open(log, 'r') as f:
                for e in json.load(f): log_metadata[e['new_name']] = e
        except Exception: continue

    for root, files in dir_groups.items():
        change_log, last_date, last_source = [], None, None
        updated_datetime = {'meta': False, 'fs': False}
        for old_path in sorted(files):
            file_eval += 1
            filename = os.path.basename(old_path)
            ext = os.path.splitext(filename)[-1].lower()
            match = FILENAME_PATTERN.match(filename.lower())
            prev = log_metadata.get(filename, {})
                        
            s_val = state_arg if state_arg is not None else prev.get("state", (match.group(2) if match else ""))
            l_val = location_arg if location_arg is not None else prev.get("location", (match.group(3) if match else ""))
            d_val = description_arg if description_arg is not None else prev.get("description", (match.group(4) if match else ""))

            if forced:
                match = False

            try:
                if match:
                    if overridden:
                        dt = datetime.strptime(match.group(1), "%Y%m%d-%H%M%S")
                        dt, source = override_dt(dt, given_date, given_time)
                    else:
                        if (match.group(2) or "") == s_val and (match.group(3) or "") == l_val and (match.group(4) or "") == d_val: continue
                        dt, source = datetime.strptime(match.group(1), "%Y%m%d-%H%M%S"), "existing"
                else:
                    if ext not in extensions: continue
                    dt, source = get_datetime(old_path)
                    if overridden:
                        dt, source = override_dt(dt, given_date, given_time)

                if adjacent and source == "modified" and last_source in ["creation", "adjacent"]:
                    dt, source = last_date, "adjacent"
                    if overridden:
                        dt, source = override_dt(dt, given_date, given_time)
            except Exception: pass

            if (ext in ('.jpeg')):
                target_ext = '.jpg'
            elif (ext in ('.tiff')):
                target_ext = '.tif'
            else:
                target_ext = ext
            
            tagged_base = dt.strftime('%Y%m%d-%H%M%S')
            for val in [s_val, l_val, d_val]:
                if val: tagged_base += f"-{val.lower()}"
            
            new_name = f"{tagged_base}{target_ext}"
            new_path = os.path.join(root, new_name)
            counter = 1
            while os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(old_path):
                new_name = f"{tagged_base}_{counter}{target_ext}"
                new_path = os.path.join(root, new_name)
                counter += 1
            
            if os.path.abspath(new_path) == os.path.abspath(old_path) and not forced: continue

            try:
                action = "adjacent" if source == "adjacent" else "renamed"
                file_cnt += 1
                if time_sequenced:
                    if not given_time:
                        given_time = datetime.strftime(dt, "%H%M%S")
                    tmp_time = int(given_time)
                    tmp_time += 1
                    given_time = str(tmp_time)
                        
                os.rename(old_path, new_path)
                if overridden:
                    updated_datetime = set_datetime(new_path, dt)

                change_log.append({
                    "original_name": filename, 
                    "original_path": os.path.abspath(old_path),
                    "new_name": new_name, 
                    "state": s_val, 
                    "location": l_val, 
                    "description": d_val,
                    "mime_type": get_mime_list(new_path),
                    "updated_datetime": updated_datetime,
                    "date_used": dt.isoformat(), 
                    "date_source": source, 
                    "action": action, 
                    "status": "success"
                })
                action_str = "[" + action.upper() + "]"
                print(f"{action_str:<11} {filename} -> {new_name}")
                last_date, last_source = dt, source
            except Exception as e: print(f"Error {filename}: {e}")

            if convert:
                updated_datetime = {'meta': False, 'fs': False}
                if ext in ext_images_convert or ext in ext_videos_convert: 
                    try:
                        action = "converted"
                        action_str = "[" + action.upper() + "]"
                        old_path = new_path
                        filename = os.path.basename(new_path)
                        if ext in ext_images_convert:
                            target_ext = '.jpg'
                        elif ext in ext_videos_convert: 
                            target_ext = '.mp4'

                        new_name = f"{tagged_base}{target_ext}"
                        new_path = os.path.join(root, new_name)
                        counter = 1
                        while os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(old_path):
                            new_name = f"{tagged_base}_{counter}{target_ext}"
                            new_path = os.path.join(root, new_name)
                            counter += 1

                        print(f"{action_str:<11} {filename} -> ", end="", flush=True)
                        if ext in ext_images_convert:
                            with Image.open(old_path) as img:
                                img.convert("RGB").save(new_path, "JPEG", quality=95)
                        elif ext in ext_videos_convert: 
                            tmp = mp.VideoFileClip(old_path)
                            clip = tmp.rotate(90)
                            clip.write_videofile(new_path, logger=None)
                            clip.close()

                        # Make the converted file have the same time as the source file
                        updated_datetime = set_datetime(new_path, dt)

                        change_log.append({
                            "original_name": filename, 
                            "original_path": os.path.abspath(old_path),
                            "new_name": new_name, 
                            "state": s_val, 
                            "location": l_val, 
                            "description": d_val,
                            "mime_type": get_mime_list(new_path),
                            "updated_datetime": updated_datetime,
                            "date_used": dt.isoformat(), 
                            "date_source": source, 
                            "action": action, 
                            "status": "success"
                        })
                        print(f"{new_name}")
                        file_eval += 1
                        file_cnt += 1

                        if convert_remove: 
                            if ext in ext_videos_convert: 
                                action_str = '[SKIPPED]'
                                print(f"{action_str:<11} {filename}, Video conversion experimental, delete manually.")
                            else:
                                action_str = '[DELETED]'
                                print(f"{action_str:<11} {filename}")
                                os.remove(old_path)

                    except Exception as e: print(f"Error {filename}: {e}")

        if change_log:
            with open(os.path.join(root, f"process_log_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"), 'w') as f:
                json.dump(change_log, f, indent=4)

    if file_cnt > 0: display_logs(target_input, verbose, all_subdirs=False)
    action_str = "[SUMMARY]"
    print(f"{action_str:<11} Processed {file_cnt} matching files out of {file_eval} found")

