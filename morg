def integrate_subdirs(target):
    notice("Integrating Subdirectory Media Files")
    recurse = True
    # start with the top directory's mediadata.json, into which subdirectory data will be integrated
    if target['single']:
        top_dir = target['single']
        msg('integrate', top_dir)
        mdata = get_media_data(top_dir)
        if mdata:
            backup_media_data_file(top_dir)
        else:
            mdata.setdefault('summary', {
                "summary_header": "",
                "summary_description": "",
                "gallery_header": "",
                "root": f"{top_dir}",
                "extra_nav_link": "", # applies to SUMMARY_FILE and INDEX_FILE
                "year": -1, # 0 for multi-year
            })
        mdata['summary'].update({"images": 0, "videos": 0, "audio": 0, "total": 0})

        # integrate subdirectories
        dir_groups = get_dir_groups(target, recurse)
        subdata = None
        for root, files in dir_groups.items():
            if root == top_dir: continue
            msg('dir', f"{root}")
            for file_path in files:
                ext = os.path.splitext(file_path)[-1].lower()
                file_name = os.path.basename(file_path)
                if file_path.endswith(MEDIA_DATA_FILE):
                    subdata = get_media_data(root)
                    if not subdata: continue
                    for group_key in subdata.keys():
                        if group_key == "summary": continue
                        if group_key in mdata:
                            for media_key in subdata[group_key].keys():
                                ext = os.path.splitext(media_key)[-1].lower()
                                if not ext in ext_all: continue
                                if not media_key in mdata[group_key]:
                                    msg('adding', f"  {group_key}: {media_key}")
                                    mdata[group_key][media_key] = subdata[group_key][media_key]
                        else:
                            msg('adding', f"  {group_key}")
                            mdata[group_key] = subdata[group_key]

                        msg('copying', f"  {group_key}: media files")
                        group_files = []
                        for media_key in subdata[group_key].keys():
                            ext = os.path.splitext(media_key)[-1].lower()
                            if ext in ext_all:
                                group_files.append(media_key)
                                cover_name = subdata[group_key][media_key].get('cover_name')
                                if cover_name: group_files.append(cover_name)
                        for file in group_files:
                            file_src = os.path.join(root, file)
                            file_dst = os.path.join(top_dir, file)
                            if os.path.exists(file_dst):
                                if not diff(file_src, file_dst, shallow=False):
                                    msg('error', f"  > file collision: {file_src} -> {file_dst}")
                            else:
                                if os.path.exists(file_src): shutil.copy(file_src, top_dir)

        with open(os.path.join(top_dir, f"{MEDIA_DATA_FILE}"), 'w') as f:
            json.dump(mdata, f, indent=4)
        print()
    else:
        msg('error', "Specify a single target directory to integerate")

def process_media(target_input, recurse, adjacent, state_arg, location_arg, description_arg, given_date, given_time, time_sequenced, forced, convert, convert_remove, default, default_maps, verbose):
    notice("Organizing Media Files")
    extensions = ext_all
    overridden = False
    file_cnt = 0
    file_eval = 0
    gps_str = ''
    if given_date or given_time or time_sequenced: overridden = True

    dir_groups = get_dir_groups(target_input, recurse)
    for root, files in dir_groups.items():
        msg('dir', f"{root}")
        mdata = get_media_data(root)
        if mdata: backup_media_data_file(root)
        mdata.setdefault('summary', {
            "summary_header": "",
            "summary_description": "",
            "gallery_header": "",
            "root": f"{root}",
            "extra_nav_link": "", # applies to SUMMARY_FILE and INDEX_FILE
            "year": -1, # 0 for multi-year
        })
        mdata['summary'].update({"images": 0, "videos": 0, "audio": 0, "total": 0})
        mdata['summary'].update({"root": f"{root}"})
        if default: mdata['summary']['year'] = -1

        last_date, last_source = None, None
        for old_path in sorted(files):
            updated_datetime = [0, 0]
            dt = ''
            file_eval += 1
            old_name = os.path.basename(old_path)
            ext = os.path.splitext(old_name)[-1].lower()
            match = FILENAME_PATTERN.match(old_name)
            group_key = ''
            old_group_key = ''
            file_group_key = ''
            found_group_key = False
            found_media_key = False
            if not ext in ext_all: continue
            if description_arg is not None:
                d_val = description_arg
            else:
                if match:
                    d_val = match.group(4)
                    if d_val == None:
                        d_val = "unassigned"
                else:
                    d_val = "unassigned"
            file_group_key = f"group-{d_val}"
#            print(f">> group_key={group_key}, file_group_key={file_group_key}")

            for group_key, group_content in mdata.items():
                # Only search inside group dictionaries, skip the summary
                if group_key.startswith("group-") and old_name in group_content:
                    found_group_key = True
                    found_media_key = True
                    break
            old_group_key = group_key
            if found_group_key:
                if group_key != file_group_key:
                    found_group_key = False
                    old_group_key = group_key
                    group_key = file_group_key
            else:
                group_key = file_group_key
            if not found_media_key:
                if group_key in mdata.keys():
                    found_group_key = True

            group_title = d_val.replace('_', ' ').title()
            mdata.setdefault(group_key, {
                "group_name": f"{group_key}.html",
                "group_header": "",
                "group_title": group_title,
                "group_description": "",
                "address": "",
                "address_url": "",
                "span": "",
                "year": -1,
                "extra_nav_link": "", # applies to group_name files
            })
            if default: mdata[group_key]['year'] = -1

#            print(f"1>                    {old_name}, gk={group_key}, ogk={old_group_key}, fgk={found_group_key}, fmk={found_media_key}")
            s_val = state_arg if state_arg is not None else (match.group(2) if match else (mdata[group_key][old_name].get('state', '') if old_name in mdata[group_key] else ''))
            l_val = location_arg if location_arg is not None else (match.group(3) if match else (mdata[group_key][old_name].get('location', '') if old_name in mdata[group_key] else ''))
            if default:
                mdata[group_key].update({'group_title': group_title})

            if forced:
                match = False

            try:
                if match:
                    if overridden:
                        dt = datetime.strptime(match.group(1), "%Y%m%d-%H%M%S")
                        dt, source = override_dt(dt, given_date, given_time), "override"
                    else:
                        dt, source = datetime.strptime(match.group(1), "%Y%m%d-%H%M%S"), "existing"
                else:
                    if ext not in extensions: continue
                    dt, source = get_datetime(old_path)
                    if overridden:
                        dt, source = override_dt(dt, given_date, given_time), "override"

                if adjacent and source == "modification" and last_source in ["creation", "adjacent"]:
                    if overridden:
                        dt, source = override_dt(dt, given_date, given_time), "override"
                    else:
                        source = "adjacent"
                        dt = last_date
                        dt += timedelta(seconds=4)
            except Exception as e:
                msg('error', f"process_media,dt/source {old_name}: {e}")
                continue

            if (ext in ('.jpeg')):
                target_ext = '.jpg'
            elif (ext in ('.tiff')):
                target_ext = '.tif'
            else:
                target_ext = ext

            tagged_base = dt.strftime('%Y%m%d-%H%M%S')
            for val in [s_val, l_val, d_val]:
                if val: tagged_base += f"-{val.lower()}"
            
            new_name = f"{tagged_base}{target_ext}"
            new_path = os.path.join(root, new_name)
            counter = 1
            while os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(old_path):
                new_name = f"{tagged_base}_{counter}{target_ext}"
                new_path = os.path.join(root, new_name)
                counter += 1
            
            file_cnt += 1
            renamed = False
            status = 'success'
            try:
                if time_sequenced:
                    if not given_time:
                        given_time = datetime.strftime(dt, "%H%M%S")
                    current_time = datetime.strptime(given_time, "%H%M%S")
                    current_time += timedelta(seconds=4)
                    given_time = current_time.strftime("%H%M%S")
            except Exception as e:
                msg('error', f"process_media,datetime {old_name}: {e}")
                status = 'failed'

            try:
                if os.path.abspath(new_path) != os.path.abspath(old_path):
                    renamed = True
                    action = "renamed"
                    os.rename(old_path, new_path)
                else:
                    action = "default" if default or default_maps else "reviewed"
                    updated_datetime = set_datetime(new_path, dt)

            except Exception as e:
                msg('error', f"process_media,{action} {old_name}: {e}")
                status = 'failed'


            if overridden:
                updated_datetime = set_datetime(new_path, dt)

            first_year = 0
            last_year = 0
            gps_str = get_gpsinfo(new_path)
            file_year = get_year(new_name)
            map_url, map_style = get_gpsurl(gps_str, l_val)
            if l_val in LOCATION_TAG:
                address = LOCATION_TAG[l_val]['addr']
                first_year = LOCATION_TAG[l_val]['begin']
                last_year = LOCATION_TAG[l_val]['end']
            elif s_val == None and l_val == None and d_val == None:
                address = "Missing"
            elif s_val != None and l_val != None:
                address = f"{l_val.replace('_', ' ').title()}, {s_val.upper()}"
            else:
                address = "Unknown"
            mime_type_list = get_mime_list(new_path)
            if mime_type_list[0] == "image":
                mdata['summary']['images'] += 1
                mdata['summary']['total'] += 1
            elif mime_type_list[0] == "video":
                mdata['summary']['videos'] += 1
                mdata['summary']['total'] += 1
            elif mime_type_list[0] == "audio":
                mdata['summary']['audio'] += 1
                mdata['summary']['total'] += 1

#            print(f"2>                    {old_name} -> {new_name}, gk={group_key}, ogk={old_group_key}, fgk={found_group_key}, fmk={found_media_key}")
            if not found_media_key:
                d = create_default_entry()
                old_media_key = ''
            else:
                d = mdata[old_group_key].pop(old_name)
                old_media_key = old_name # in case it needs deleting by convert_remove

            d.update({"new_name": new_name})
            if renamed: d.update({'prev_name': old_name})
            if not d.get('orig_name'): d.update({'orig_name': old_name})
            if not d.get('gallery_caption'): d.update({'gallery_caption': group_title})
            if default: d.update({'gallery_caption': group_title})
            if l_val in LOCATION_TAG:
                d.update({'first_year': first_year, 'last_year': last_year})
            d.update({"year": file_year, "state": s_val, "location": l_val, "description": d_val})
            d.update({"gps": gps_str})
            d.update({"mime_type": mime_type_list})
            d["updated_datetime"].update({"meta": updated_datetime[0], "fs": updated_datetime[1]})
            d.update({"date_used": dt.isoformat()})
            d.update({"date_source": source})
            if default_maps:
                d.update({'map_url': map_url})
                d.update({'map_style': map_style})
            else:
                if not d.get('map_url'): d.update({'map_url': map_url})
                if not d.get('map_style'): d.update({'map_style': map_style})
            if ext in ext_videos or ext in ext_sounds:
                cover_name = f"{tagged_base}.jpg"
                new_path = os.path.join(root, new_name)
                d.update({'duration': get_av_duration(new_path), 'cover_name': cover_name})
                e = mdata[group_key].pop(cover_name, None)
                if e:
                    mdata['summary']['images'] -= 1
                    mdata['summary']['total'] -= 1
                    msg('deleted', f"    {cover_name} -> Cover duplicate")
            d['rev'].append([log_time, action])

            if default_maps:
                mdata[group_key].update({'address': address})
                if map_style == 1: mdata[group_key].update({'address_url': map_url})
            else:
                if not mdata[group_key].get('address'): mdata[group_key].update({'address': address})
                if not mdata[group_key].get('address_url') and map_style == 1: mdata[group_key].update({'address_url': map_url})

            group_year = mdata[group_key].get('year')
            if group_year < 0:
                mdata[group_key].update({'year': file_year})
            else:
                if group_year != file_year:
                    mdata[group_key].update({'year': 0})
            group_year = mdata[group_key].get('year')

            year_str = f" {group_year}" if group_year > 0 else ""
            if not mdata[group_key].get('group_header'): mdata[group_key].update({'group_header': f"Year{year_str}"})
            if default: mdata[group_key].update({'group_header': f"Year{year_str}"})

            time_frame = f" <em>({first_year}-{last_year})</em>"
            if first_year == 0:
                time_frame = ''
            elif last_year == 0:
                time_frame = f" <em>({first_year}-Present)</em>"
            mdata[group_key].update({'span': time_frame})


            summary_year = mdata['summary'].get('year')
            if summary_year < 0:
                mdata['summary'].update({'year': file_year})
            else:
                if summary_year != file_year:
                    mdata['summary'].update({'year': 0})
            d.update({'status': status})


            if renamed:
                mdata[group_key][new_name] = d
            else:
                mdata[group_key][old_name] = d

            gps_id = "-" if gps_str == "N/A" else "+"
            msg(action, f"{updated_datetime[0]}{updated_datetime[1]}{gps_id} {old_name} -> {new_name} ({source})")
            last_date, last_source = dt, source

            if convert:
                updated_datetime = [0, 0]
                conversion_key = new_name
                if ext in ext_images_convert or ext in ext_videos_convert or ext in ext_sounds_convert: 
                    action = "converted"
                    c = copy.deepcopy(mdata[group_key].get(new_name))
                    c['status'] = "success"
                    old_path = new_path
                    old_name = os.path.basename(new_path)
                    if ext in ext_images_convert:
                        target_ext = '.jpg'
                    elif ext in ext_videos_convert: 
                        target_ext = '.mp4'
                    elif ext in ext_sounds_convert: 
                        target_ext = '.mp3'

                    new_name = f"{tagged_base}{target_ext}"
                    new_path = os.path.join(root, new_name)
                    counter = 1
                    while os.path.exists(new_path) and os.path.abspath(new_path) != os.path.abspath(old_path):
                        new_name = f"{tagged_base}_{counter}{target_ext}"
                        new_path = os.path.join(root, new_name)
                        counter += 1

                    msg(action, f"    {old_name} -> ", flush=True)
                    if ext in ext_images_convert:
                        try:
                            with Image.open(old_path) as img:
                                img.convert("RGB").save(new_path, "JPEG", quality=95)
                        except Exception as e:
                            print()
                            msg('error', f"process_media,{action},Image.convert: {e}")
                            c['status'] = "failed"
                            pass
                    elif ext in ext_videos_convert:
                        hb = HandBrake()
                        preset = hb.get_preset("CLI Default")
                        try:
                            hb.convert_title(
                                old_path, 
                                new_path, 
                                "1"
                            )
                        except Exception as e:
                            print()
                            msg('error', f"process_media,{action},HandBrake: {e}")
                            c['status'] = "failed"
                            pass
                    elif ext in ext_sounds_convert:
                        try:
                            audio = AudioSegment.from_file(old_path)
                            audio.export(new_path, format="mp3")
                        except Exception as e:
                            print()
                            msg('error', f"process_media,{action},AudioSegment: {e}")
                            c['status'] = "failed"
                            pass

                    msg('', f"{new_name}")

                    mime_type_list = get_mime_list(new_path)
                    if mime_type_list[0] == "image":
                        mdata['summary']['images'] += 1
                        mdata['summary']['total'] += 1
                    elif mime_type_list[0] == "video":
                        mdata['summary']['videos'] += 1
                        mdata['summary']['total'] += 1
                    elif mime_type_list[0] == "audio":
                        mdata['summary']['audio'] += 1
                        mdata['summary']['total'] += 1

                    # Make the converted file have the same time as the source file
                    updated_datetime = set_datetime(new_path, dt)

                    c['orig_name'] = new_name
                    c['new_name'] = new_name
                    c['prev_name'] = new_name
                    c['mime_type'] = mime_type_list
                    c['updated_datetime'].update({'meta': updated_datetime[0], 'fs': updated_datetime[1]})
                    c['date_used'] = dt.isoformat()
                    c['date_source'] = source
                    c['rev'].append([log_time, action])

                    mdata[group_key].setdefault(new_name, c)
                    file_eval += 1
                    file_cnt += 1

                    gps_id = "-" if mdata[group_key][conversion_key]['gps'] == "N/A" else "+"
                    msg('updated', f"{updated_datetime[0]}{updated_datetime[1]}{gps_id} {new_name} (existing)")
                    if convert_remove and c['status'] == "success": 
                        msg('deleted', f"    {old_name} -> Removed converted media entry")
                        mdata[group_key].pop(conversion_key)
                        os.remove(old_path)


        summary_year = mdata['summary'].get('year')
        year_str = f" {summary_year}" if summary_year > 0 else ""
        if not mdata['summary'].get('summary_header'): mdata['summary'].update({'summary_header': f"Summary{year_str}"})
        if not mdata['summary'].get('gallery_header'): mdata['summary'].update({'gallery_header': f"Media Gallery{year_str}"})
        if default:
            mdata['summary'].update({'summary_header': f"Summary{year_str}"})
            mdata['summary'].update({'gallery_header': f"Media Gallery{year_str}"})

        # Remove keys with missing filenames on the disk
        missing_keys = []
        for group_key in mdata.keys():
            for media_key in mdata[group_key].keys():
                ext = os.path.splitext(media_key)[-1].lower()
                if not ext in ext_all: continue
                new_name = mdata[group_key][media_key].get('new_name')
                filename = os.path.join(root, new_name)
                if not os.path.exists(filename):
                    missing_keys.append([group_key, media_key])

        for group_key, media_key in missing_keys:
            mdata[group_key].pop(media_key, None)
            msg('deleted', f"    {group_key},{media_key} key -> File not found")

        # Removed empty group keys and their associated filenames
        empty_groups = []
        for group_key in mdata.keys():
            empty = True
            if group_key.startswith("summary"): continue
            for media_key in mdata[group_key].keys():
                ext = os.path.splitext(media_key)[-1].lower()
                if ext in ext_all:
                    empty = False
                    break
            if empty: empty_groups.append(group_key)

        for key in empty_groups:
            group_name = mdata[key].get('group_name')
            filename = os.path.join(root, group_name)
            if os.path.exists(filename): os.remove(filename)
            mdata.pop(key, None)
            msg('deleted', f"    {key} key -> Empty group and associated filename")

        # Move cover_name data to associated audio/visual keys
        keys_to_pop = []
        for group_key in mdata.keys():
            for media_key in mdata[group_key].keys():
                tagged_base, ext = os.path.splitext(media_key)
                if ext in ext_images:
                    old_path = mdata[group_key][media_key].get('new_name')
                    av_key = mdata[group_key][media_key].get('cover_name')
                    if av_key:
                        if av_key in mdata[group_key]:
                            md = mdata[group_key][media_key].get('media_description')
                            pl = mdata[group_key][media_key].get('people_list')
                            gc = mdata[group_key][media_key].get('gallery_caption')
                            new_path = mdata[group_key][av_key].get('cover_name')
                            msg('rename', f"Cover file:      {old_path} -> {new_path}")
                            os.rename(old_path, new_path)
                            msg('copy',   f"Data:            {old_path} -> {av_key}")
                            mdata[group_key][av_key]['media_description'] = md
                            mdata[group_key][av_key]['people_list'] = pl
                            mdata[group_key][av_key]['gallery_caption'] = gc
                            keys_to_pop.append([group_key, media_key])
                        else:
                            msg('error', f"Invalid av_key for {group_key}/{av_key}")

        for group_key, media_key in keys_to_pop:
            msg('remove', f"Cover duplicate: {media_key}")
            mdata[group_key].pop(media_key, None)

        with open(os.path.join(root, f"{MEDIA_DATA_FILE}"), 'w') as f:
            json.dump(mdata, f, indent=4)

    msg('summary', f"Processed {file_cnt} matching files out of {file_eval} found\n")

