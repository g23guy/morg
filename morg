def reverse_last_session(target, recurse):
    notice("Restoring Media Files from Last Session, Except Converted Files")
    dir_groups = get_dir_groups(target, recurse)

    for root, files in dir_groups.items():
        msg('dir', root)
        mdata = get_media_data(root)
        if not mdata:
            msg('error', f"File not found - {MEDIA_DATA_FILE}, run 'morg .' first")
            return
        else:
            backup_media_data_file(root)

        actions = {}
        for group_key in mdata.keys():
            for media_key in mdata[group_key].keys():
                entry = mdata[group_key][media_key]
                ext = os.path.splitext(media_key)[-1].lower()
                if not ext in ext_all: continue
                if entry.get('status') == 'success':
                    curr, prev, logged, action = entry.get('new_name'), entry.get('prev_name'), entry['rev'][-1][0], entry['rev'][-1][1]
                if not logged in actions:
                    actions[logged] = []
                actions[logged].append([logged, action, curr, prev])
        last_session = ''
        for session in actions.keys():
            if session > last_session:
                last_session = session
        reverse_session = actions.get(last_session)
        restore_reset = False
        restore_default = False
        restore_main = False
        for logged, action, curr, prev in reverse_session:
            if action == 'renamed':
                if os.path.exists(curr):
                    restore_main = True
                    os.rename(curr, prev)
                    msg('reversed', f"{curr} -> {prev}")
            elif action == 'converted':
                msg('converted', f"{curr} -> {prev}: Cannot be restored")
            elif action == 'reviewed':
                msg('reviewed', f"{curr} -> Nothing to restore")
            elif action == 'reset':
                restore_reset = True
            elif action == 'default':
                restore_default = True

        filename = f"{MEDIA_DATA_FILE}-backup-{logged}.json"
        backup_file = os.path.join(root, filename)
        data_file = os.path.join(root, MEDIA_DATA_FILE)
        if restore_main:
            if os.path.exists(backup_file):
                shutil.copy(backup_file, data_file)
                msg('reversed', f"{filename} -> {MEDIA_DATA_FILE}")
            else:
                msg('error', f"{filename} -> File not found")
        elif restore_reset:
            if os.path.exists(backup_file):
                shutil.copy(backup_file, data_file)
                msg('reset', f"{filename} -> {MEDIA_DATA_FILE}")
            else:
                msg('error', f"{filename} -> File not found")
        elif restore_default:
            if os.path.exists(backup_file):
                shutil.copy(backup_file, data_file)
                msg('default', f"{filename} -> {MEDIA_DATA_FILE}")
            else:
                msg('error', f"{filename} -> File not found")
            
        print()

