def get_av_duration(file):
    cmd = [
        "ffprobe", "-v", "error", 
        "-show_entries", "format=duration", 
        "-of", "default=noprint_wrappers=1:nokey=1", 
        "-sexagesimal", file
    ]
    extracted = ''

    try:
        # Get output (e.g., "0:00:57.190000")
        output = subprocess.check_output(cmd).decode('utf-8').strip()

        # Extraction logic:
        # 1. Split at '.' to remove microseconds ("0:00:57")
        # 2. Split by ':' and take the last two segments
        time_parts = output.split('.')[0].split(':')
        hh = time_parts[-3].zfill(2) # Pad with zero if needed
        mm = time_parts[-2].zfill(2)
        ss = time_parts[-1].zfill(2)
        if hh != "00":
            extracted = f"{hh}:{mm}:{ss}"
        else:
            extracted = f"{mm}:{ss}"

    except subprocess.CalledProcessError as e:
        msg('error', f"get_av_duration: ffprobe {file}: {e}")

    return extracted

