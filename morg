    parser.add_argument("-G", "--all-logs", action="store_true", help="Display latest JSON log summary in all subdirs")
    parser.add_argument("-v", "--verbose", action="store_true", help="Enables verbose output")
    parser.add_argument("-s", "--state", help="State tag")
    parser.add_argument("-l", "--location", help="Location tag")
    parser.add_argument("-d", "--description", help="Description tag")
    parser.add_argument("-D", "--yyyymmdd", type=date_digits, help="Override meta creation(if possible) and filesystem modification date value, requires 8 digits")
    parser.add_argument("-T", "--hhmmss", type=time_digits, help="Override meta creation(if possible) and filesystem modification time value, requires 6 digits")
    parser.add_argument("-t", "--time-sequenced", action="store_true", help="Use -T/--hhmmss time if given, or the first file's time and increment it for sebsequent files")
    
    if len(sys.argv) == 1: parser.print_help(); sys.exit(1)
    args = parser.parse_args()

    if args.convert_remove: args.convert = True 
    if args.original: restore_original_names(args.folder, args.recurse)
    elif args.all_logs: display_logs(args.folder, args.verbose, all_subdirs=True)
    elif args.log: display_logs(args.folder, args.verbose, all_subdirs=False)
    elif args.reverse: reverse_last_session(args.folder, args.recurse)
    elif args.modified: filename_to_modification_dt(args.folder, args.recurse, args.verbose)
    else: process_media(args.folder, args.recurse, args.adjacent, args.state, args.location, args.description, args.yyyymmdd, args.hhmmss, args.time_sequenced, args.force, args.convert, args.convert_remove, args.verbose)
    

