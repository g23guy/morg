# Regex: YYYYMMDD-HHMMSS[-State][-Location][-Description](_#).ext
# group(1): YYYYMMDD-HHMMSS
# group(2): [-State]
# group(3): [-Location]
# group(4): [-Description]
FILENAME_PATTERN = re.compile(r"^(\d{8}-\d{6})(?:-([^-_\.]+))?(?:-([^-\.]+))?(?:-([^-\.]+))?(?:_(\d+))?\.(" + ext_all_str + ")$")

# Filename style: Android
# Regex: YYYYMMDD_HHMMSS.ext
# group(1): YYYYMMDD_HHMMSS
# ANDROID_PATTERN = re.compile(r"^(\d{8}_\d{6})\.(" + ext_image_str + ")$")
ANDROID_PATTERN = re.compile(r"^(?:img_|vid_)?(\d{8}_\d{6})(?:\d{3})?\.(" + ext_all_str + ")$")

# Filename style: Linux Screen Shot
# Regex: Screenshot from YYYY-MM-DD HH-MM-SS.ext
# group(1): YYYY-MM-DD HH-MM-SS
SSLINUX_PATTERN = re.compile(r"^Screenshot from (\d{4}-\d{2}-\d{2} \d{2}-\d{2}-\d{2})\.(" + ext_image_str + ")$", re.IGNORECASE)

# Filename style: Windows Screen Shots
# Regex: Screenshot YYYY-MM-DD HHMMSS.png or screenshot_YYYY-MM-DD_HHMMSS.png
# group(1): YYYY-MM-DD
# group(2): HHMMSS
SSWINDOWS_PATTERN = re.compile(r"^Screenshot[_ ](\d{4}-\d{2}-\d{2})[_ ](\d{6})\.(" + ext_image_str + ")$", re.IGNORECASE)

