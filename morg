def msg(action, msg, flush=False):
    if action:
        action_str = "[" + action.upper() + "]"
        if flush:
            print(f"{action_str:<11} {msg}", end="", flush=True)
        else:
            print(f"{action_str:<11} {msg}")
    else:
        print(f"{msg}")

