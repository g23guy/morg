def get_mime_list(filepath):
    mime_type, _ = mimetypes.guess_type(filepath)
    if mime_type:
        parts = mime_type.split('/')
        return [parts[0], parts[-1]]
    return ["unknown", "unknown"]

def get_gpsinfo(filepath):
    """Extracts GPS Latitude and Longitude using ExifToolHelper."""
    gpsinfo = 'None'
    try:
        with exiftool.ExifToolHelper() as et:
            # get_tags returns a list of dictionaries (one per image)
            for d in et.get_tags(filepath, tags=['GPSLatitude', 'GPSLongitude']):
                # Tags are prefixed with the group name (e.g., 'EXIF:')
                lat = d.get('Composite:GPSLatitude')
                lon = d.get('Composite:GPSLongitude')
                
                if lat is not None and lon is not None:
                    gpsinfo = f"{lat},{lon}"
    except Exception: pass
    return gpsinfo

def get_datetime(filepath):
    ext = os.path.splitext(filepath)[-1].lower()
    filename = os.path.basename(filepath)

    # Look for supported filename styles
    android_style = ANDROID_PATTERN.match(filename.lower())

    # Date Priority 1: Meta Date/Time
    if ext in ext_images:
        sslinux_style = SSLINUX_PATTERN.match(filename.lower())
        sswin_style = SSWINDOWS_PATTERN.match(filename.lower())
        try:
            with Image.open(filepath) as img:
                exif_data = img._getexif()
                if exif_data:
                    for tag, value in exif_data.items():
                        if TAGS.get(tag) == "DateTimeOriginal":
                            return datetime.strptime(value, "%Y:%m:%d %H:%M:%S"), "creation"
                        elif TAGS.get(tag) == "DateTimeDigitized":
                            return datetime.strptime(value, "%Y:%m:%d %H:%M:%S"), "digitized"
        except Exception: pass

    # Date Priority 2: Supported Filename Style Date/Time
        try:
            if android_style:
                return datetime.strptime(android_style.group(1), "%Y%m%d_%H%M%S"), "android"
            elif sslinux_style:
                return datetime.strptime(sslinux_style.group(1), "%Y-%m-%d %H-%M-%S"), "sslinux"
            elif sswin_style:
                value = sswin_style.group(1) + "_" + sswin_style.group(2)
                return datetime.strptime(value, "%Y-%m-%d_%H%M%S"), "sswin"
        except Exception: pass

    # Date Priority 1: Meta Date/Time
    if ext in ext_videos or ext in ext_sounds:
        try:
            with exiftool.ExifToolHelper() as et:
                metadata = et.get_metadata(filepath)
                for d in metadata:
                    value = d.get('EXIF:DateTimeOriginal') or d.get('XMP:DateTimeOriginal') or d.get('QuickTime:CreateDate')
                    return datetime.strptime(value, "%Y:%m:%d %H:%M:%S"), "creation"
        except Exception: pass

    # Date Priority 2: Supported Filename Style Date/Time
        try:
            if android_style:
                return datetime.strptime(android_style.group(1), "%Y%m%d_%H%M%S"), "android"
        except Exception: pass

    # Date Priority 3: Filesystem Modification Date/Time
    return datetime.fromtimestamp(os.path.getmtime(filepath)), "modified"

def set_datetime(file_path, dt):
    updated_datetime = {'meta': 0, 'fs': 0}
    ext = os.path.splitext(file_path)[-1].lower()
    dt_stamp = dt.timestamp()
    new_date = dt.strftime("%Y:%m:%d %H:%M:%S")

    if ext in ext_images:
        try:
            with Image.open(file_path) as img:
                exif_dict = piexif.load(img.info.get('exif', b""))
                exif_dict['Exif'][piexif.ExifIFD.DateTimeOriginal] = new_date.encode('utf-8')
                exif_dict['Exif'][piexif.ExifIFD.DateTimeDigitized] = new_date.encode('utf-8')
                exif_bytes = piexif.dump(exif_dict)
                img.save(file_path, exif=exif_bytes)
            updated_datetime['meta'] = 1
        except Exception: pass

    if ext in ext_videos or ext in ext_sounds:
        tags_to_set = {
            "EXIF:DateTimeOriginal": new_date,
            "XMP:DateTimeOriginal": new_date,
            "QuickTime:CreateDate": new_date
        }
        params = ["-P", "-overwrite_original"]

        try:
            with exiftool.ExifToolHelper() as et:
                # Note: set_tags expects a list of files even if it's just one
                et.set_tags([file_path], tags=tags_to_set, params=params)
            updated_datetime['meta'] = 1
        except Exception: pass

    try:
        os.utime(file_path, (dt_stamp, dt_stamp))
        updated_datetime['fs'] = 1
    except Exception: pass

    return updated_datetime

def override_dt(dt_old, given_date, given_time):
    if given_date:
        new_date = given_date
    else:
        new_date = datetime.strftime(dt_old, "%Y%m%d")

    if given_time:
        new_time = given_time
    else:
        new_time = datetime.strftime(dt_old, "%H%M%S")

    dt_new_str = new_date + "-" + new_time
    dt_new = datetime.strptime(dt_new_str, "%Y%m%d-%H%M%S")
    return dt_new, "override"

